#!/usr/bin/env bash
set -euo pipefail

# Do not run auto-sync from pre-commit. Calling auto-sync here causes a recursive
# commit loop because auto-sync itself creates commits. Use `npm run sync` or
# `npm run watch:sync` explicitly after making changes.
if [ "${AUTO_SYNC_IN_PROGRESS:-}" = "1" ]; then
  echo "✅ auto-sync commit detected; skipping recursive sync hook"
  exit 0
fi

echo "✅ pre-commit hook complete"
