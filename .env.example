# Supabase Configuration — Get from https://app.supabase.com/project/*/settings/api
# Publishable key (safe to expose in browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.EXAMPLE
VITE_SUPABASE_PROJECT_ID=your-project-id

# Server-only: Publishable key (same as above, for server functions)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.EXAMPLE

# ⚠️ CRITICAL: SUPABASE_SERVICE_ROLE_KEY is only set in production Cloudflare Workers environment
# Never add it to .env or commit to repository — it bypasses Row Level Security
# Set via: wrangler secret put SUPABASE_SERVICE_ROLE_KEY

# Supabase Pooler for connection pooling (serverless)
# SUPABASE_DB_POOL_URL=postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Cloudflare Workers — security secret for cron endpoints
# Generate: openssl rand -base64 32
CRON_SECRET=replace-with-strong-random-string

# Optional API Keys (set in environment/wrangler secrets, not in .env)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# SECTORS_API_KEY=...
# VITE_POSTHOG_KEY=phc_...
# FRED_API_KEY=...
# VAPID_PUBLIC_KEY=... (for push notifications)
# VAPID_PRIVATE_KEY=... (for push notifications)
